# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database (로컬: docker-compose, 프로덕션: Railway)
DATABASE_URL=postgresql://sketch:sketch@localhost:5432/sketchcatch?schema=public

# Redis (로컬: docker-compose, 프로덕션: Railway)
REDIS_URL=redis://localhost:6379

# 인증 (Phase 2에서 사용)
KAKAO_REST_KEY=your-kakao-rest-api-key
APPLE_BUNDLE_ID=com.sketchcatch.app
JWT_SECRET=replace-with-strong-random-32-bytes-or-more

# 푸시 (Phase 7에서 사용, 옵션)
EXPO_ACCESS_TOKEN=
